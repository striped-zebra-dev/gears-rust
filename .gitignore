# Generated by Cargo
# will have compiled files and executables
debug
target
logs
# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
.idea/
.vscode/

# Submodules

# Ignore stray local clone of the old top-level hapig repo (submodule lives under guidelines/)
/hapig/

.cargo/advisory-db
.DS_Store
/.venv/*
**/__pycache__

# Code coverage reports
/coverage/

# Fuzzing artifacts
/fuzz/target/
/fuzz/artifacts/
/fuzz/corpus/**
!/fuzz/corpus/*/
!/fuzz/corpus/*/.gitkeep

# Claude Code local settings
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Cypilot per-task plan artifacts (scratch data; not tracked)
.cypilot/.plans/

CLAUDE.local.md
.setup-stamp

# PR review runtime data (fetched from GitHub, numeric PR folders)
.prs/[0-9]*/

# E2E test credentials and venv
testing/e2e/.env.e2e
testing/e2e/.env.e2e.*
testing/e2e/.venv/
testing/e2e/logs/
.docker-stage

# Cypilot per-task working data (scratch reviews, logs, prompts; not tracked)
.cypilot/work/

